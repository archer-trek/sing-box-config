{
  "log": {
    "level": "warn",
    "timestamp": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",
      "secret": "",
      "external_ui_download_url": "https://github.com/MetaCubeX/metacubexd/archive/refs/heads/gh-pages.zip",
      "default_mode": "rule"
    }
  },
  "dns": {
    "servers": [
      {
        "tag": "dns_proxy",
        "type": "https",
        "server": "1.1.1.1",
        "detour": "DNS"
      },
      {
        "tag": "dns_ai",
        "type": "https",
        "server": "1.1.1.1",
        "detour": "AI"
      },
      {
        "tag": "dns_direct",
        "type": "https",
        "server": "doh.pub",
        "domain_resolver": "dns_resolver"
      },
      {
        "tag": "dns_resolver",
        "type": "tcp",
        "server": "223.5.5.5"
      }
    ],
    "rules": [
      {
        "domain_keyword": [
          "_dns-sd._udp"
        ],
        "action": "predefined",
        "rcode": "NXDOMAIN"
      },
      {
        "clash_mode": "direct",
        "server": "dns_direct"
      },
      {
        "wifi_ssid": [
          "sanzhixiaoxiong"
        ],
        "server": "dns_direct"
      },
      {
        "domain": [
          "stun.easyvoip.com"
        ],
        "server": "dns_direct"
      },
      {
        "domain_suffix": [
          "sensorsdata.cn",
          "codexzh.com"
        ],
        "server": "dns_direct"
      },
      {
        "rule_set": [
          "cn"
        ],
        "server": "dns_direct"
      },
      {
        "rule_set": [
          "ai"
        ],
        "server": "dns_ai"
      },
      {
        "rule_set": [
          "proxy"
        ],
        "server": "dns_proxy"
      }
    ],
    "final": "dns_direct",
    "strategy": "ipv4_only",
    "disable_cache": false,
    "disable_expire": false,
    "independent_cache": false,
    "reverse_mapping": true
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "sing-box-utun",
      "address": [
        "172.19.0.1/30"
      ],
      "auto_route": true,
      "strict_route": true
    }
  ],
  "outbounds": [
    {
      "tag": "默认策略",
      "type": "selector",
      "outbounds": [
        "香港节点",
        "台湾节点",
        "日本节点",
        "新加坡节点",
        "美国节点",
        "My 节点",
        "World 节点",
        "良心云节点",
        "ALL",
        "直连"
      ],
      "default": "香港节点",
      "interrupt_exist_connections": false
    },
    {
      "tag": "DNS",
      "type": "selector",
      "outbounds": [
        "香港节点",
        "台湾节点",
        "日本节点",
        "新加坡节点",
        "美国节点",
        "My 节点",
        "World 节点",
        "良心云节点",
        "ALL",
        "直连"
      ],
      "default": "ALL",
      "interrupt_exist_connections": false
    },
    {
      "tag": "AI",
      "type": "selector",
      "outbounds": [
        "香港节点",
        "台湾节点",
        "日本节点",
        "新加坡节点",
        "美国节点",
        "My 节点",
        "World 节点",
        "良心云节点"
      ],
      "default": "台湾节点",
      "interrupt_exist_connections": false
    },
    {
      "tag": "Netflix",
      "type": "selector",
      "outbounds": [
        "香港节点",
        "台湾节点",
        "日本节点",
        "新加坡节点",
        "美国节点",
        "My 节点",
        "World 节点",
        "良心云节点"
      ],
      "default": "香港节点",
      "interrupt_exist_connections": false
    },
    {
      "tag": "YouTube",
      "type": "selector",
      "outbounds": [
        "香港节点",
        "台湾节点",
        "日本节点",
        "新加坡节点",
        "美国节点",
        "My 节点",
        "World 节点",
        "良心云节点"
      ],
      "default": "香港节点",
      "interrupt_exist_connections": false
    },
    {
      "tag": "直连",
      "type": "direct"
    },
    {
      "tag": "My 节点",
      "type": "selector",
      "outbounds": [
        "{My-}"
      ],
      "interrupt_exist_connections": false
    },
    {
      "tag": "World 节点",
      "type": "selector",
      "outbounds": [
        "{World-}"
      ],
      "interrupt_exist_connections": false
    },
    {
      "tag": "良心云节点",
      "type": "selector",
      "outbounds": [
        "{良心云-}"
      ],
      "interrupt_exist_connections": false
    },
    {
      "tag": "ALL",
      "type": "urltest",
      "outbounds": [
        "{.*}"
      ],
      "interrupt_exist_connections": false
    },
    {
      "tag": "香港节点",
      "type": "urltest",
      "outbounds": [
        "{(?i)World-.*(港|香港|hk|hongkong|hong kong)}"
      ],
      "interrupt_exist_connections": false
    },
    {
      "tag": "台湾节点",
      "type": "urltest",
      "outbounds": [
        "{(?i)World-.*(台|台湾|tw|taiwan)}"
      ],
      "interrupt_exist_connections": false
    },
    {
      "tag": "日本节点",
      "type": "urltest",
      "outbounds": [
        "{(?i)World-.*(日本|jp|japan)}"
      ],
      "interrupt_exist_connections": false
    },
    {
      "tag": "新加坡节点",
      "type": "urltest",
      "outbounds": [
        "{(?i)World-.*(新加坡|新|sg|singapore)}"
      ],
      "interrupt_exist_connections": false
    },
    {
      "tag": "美国节点",
      "type": "urltest",
      "outbounds": [
        "{(?i)World-.*(美国|美|us|unitedstates|united states)}"
      ],
      "interrupt_exist_connections": false
    }
  ],
  "route": {
    "rules": [
      {
        "action": "sniff"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "clash_mode": "direct",
        "outbound": "直连"
      },
      {
        "wifi_ssid": [
          "sanzhixiaoxiong"
        ],
        "outbound": "直连"
      },
      {
        "ip_cidr": [
          "104.223.57.43"
        ],
        "outbound": "直连"
      },
      {
        "rule_set": [
          "private",
          "privateip"
        ],
        "outbound": "直连"
      },
      {
        "domain": [
          "stun.easyvoip.com"
        ],
        "outbound": "直连"
      },
      {
        "domain_suffix": [
          "sensorsdata.cn",
          "codexzh.com"
        ],
        "outbound": "直连"
      },
      {
        "rule_set": [
          "cnip"
        ],
        "outbound": "直连"
      },
      {
        "rule_set": [
          "cn"
        ],
        "outbound": "直连"
      },
      {
        "rule_set": [
          "ai"
        ],
        "outbound": "AI"
      },
      {
        "rule_set": [
          "netflix",
          "netflixip"
        ],
        "outbound": "Netflix"
      },
      {
        "rule_set": [
          "youtube"
        ],
        "outbound": "YouTube"
      }
    ],
    "rule_set": [
      {
        "tag": "private",
